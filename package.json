{
  "name": "auth-template-cloudflare",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create auth-db",
    "db:migrate": "wrangler d1 execute auth-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute auth-db --local --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "jose": "^5.2.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.57.0"
  }
}
